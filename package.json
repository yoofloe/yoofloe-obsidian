{
  "name": "obsidian-yoofloe",
  "version": "0.3.5",
  "description": "Yoofloe AI insight documents grounded in your data.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "build:mcp": "node esbuild.mcp.mjs production",
    "dev": "node esbuild.config.mjs --watch",
    "dev:mcp": "node esbuild.mcp.mjs --watch",
    "start:mcp": "node mcp-server.js",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "security:audit": "npm audit --audit-level=high",
    "security:snyk:oss": "npx --yes snyk@1.1304.0 test --severity-threshold=high --fail-on=all",
    "security:scan": "npm run security:audit && npm run security:snyk:oss"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.25.2",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.4",
    "globals": "^17.5.0",
    "obsidian": "^1.8.10",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.16"
  }
}
