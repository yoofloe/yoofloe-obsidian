{
  "name": "obsidian-yoofloe",
  "version": "0.1.1",
  "description": "Yoofloe reports, recaps, and optional BYOK AI notes inside Obsidian.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "build:mcp": "node esbuild.mcp.mjs production",
    "dev": "node esbuild.config.mjs --watch",
    "dev:mcp": "node esbuild.mcp.mjs --watch",
    "start:mcp": "node mcp-server.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "esbuild": "^0.25.2",
    "obsidian": "^1.8.10",
    "typescript": "^5.8.3"
  }
}
